{
  "name": "@open-agent-sdk/tools",
  "version": "0.1.0",
  "description": "Standard tools for open-agent-sdk (Bash, Read, Write, Edit, Glob, Grep, AskUser, etc.)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@open-agent-sdk/core": "workspace:*",
    "zod": "^3.0.0"
  },
  "peerDependencies": {
    "ai": ">=6.0.0",
    "parallel-web": "*"
  },
  "peerDependenciesMeta": {
    "parallel-web": {
      "optional": true
    }
  },
  "devDependencies": {
    "ai": "^6.0.0",
    "typescript": "^5.0.0",
    "tsup": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
