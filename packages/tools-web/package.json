{
  "name": "@open-agent-sdk/tools-web",
  "version": "0.1.0",
  "description": "Web tools for open-agent-sdk (WebFetch, WebSearch) powered by parallel-web",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./src/index.ts",
        "default": "./src/index.ts"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@open-agent-sdk/core": "workspace:*",
    "parallel-web": "*"
  },
  "peerDependencies": {
    "ai": ">=6.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "ai": "^6.0.0",
    "typescript": "^5.0.0",
    "tsup": "^8.0.0",
    "vitest": "^3.0.0",
    "zod": "^3.0.0"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.cjs"
        }
      }
    }
  }
}
