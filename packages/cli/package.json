{
  "name": "@open-agent-sdk/cli",
  "version": "0.1.0",
  "description": "oa — a standalone CLI coding agent powered by Open Agent SDK",
  "license": "MIT",
  "type": "module",
  "bin": {
    "oa": "dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "tsx src/cli.ts",
    "build": "tsup",
    "compile": "cd /tmp && bun build $OLDPWD/src/cli.ts --compile --outfile $OLDPWD/dist/oa",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@open-agent-sdk/core": "workspace:*",
    "@open-agent-sdk/sandbox-local": "workspace:*",
    "@open-agent-sdk/tools": "workspace:*",
    "@open-agent-sdk/skills": "workspace:*",
    "ai": "^6.0.0",
    "dotenv": "^16.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "tsx": "^4.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
